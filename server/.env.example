# Database
MONGO_URI=mongodb://localhost:27017/bubbleflash

# JWT Secret (use a secure random string in production)
JWT_SECRET=your_jwt_secret_here

# Google OAuth (Get these from Google Cloud Console)
# Authorized redirect URI in Google Cloud Console must be:
#   BACKEND_URL/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Full callback URL registered in Google Cloud Console
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Backend public URL (used to build the callback URL above)
BACKEND_URL=http://localhost:5000

# Web app URL – users who sign in via a browser are redirected here after OAuth
WEB_URL=http://localhost:3000

# Native app deep-link scheme – Capacitor app users are redirected here after OAuth
# The app must register this scheme in AndroidManifest.xml / Info.plist
APP_DEEP_LINK=com.bubbleflashservices.bfsapp://google-success

# Server Port
PORT=5000

# Base URL for frontend redirects (legacy alias, prefer WEB_URL)
BASE_URL=http://localhost:3000

# Email configuration (for OTP and password reset)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Twilio (for SMS OTP)
TWILIO_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM=+1234567890

# Google Maps API (for address autocomplete)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
