# Mobile App Environment Variables
# Copy this file to .env and fill in your values

# Backend API URL (your deployed server URL)
EXPO_PUBLIC_API_URL=https://bfs-api.onrender.com/api

# Google OAuth Client IDs
# Get these from: https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client IDs for:
#   1. Web application (for Expo Go / development)
#   2. Android
#   3. iOS
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_web_client_id_here
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_android_client_id_here.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_ios_client_id_here.apps.googleusercontent.com
